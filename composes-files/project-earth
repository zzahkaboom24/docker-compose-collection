volumes:
  genoa-objectstore_data:
    name: genoa-objectstore_data
  genoa-static_data:
    name: genoa-static_data
  genoa-db_data:
    name: genoa-db_data
  genoa-resourcepack_data:
    name: genoa-resourcepack_data
  genoa-world_data:
    name: genoa-world_data

services:
  eventbus:
    container_name: ProjectGenoaEventbus
    image: micheal65536/vienna:eventbus-latest
    hostname: eventbus
    networks:
      - genoa_internal
    restart: unless-stopped

  objectstore:
    container_name: ProjectGenoaObjectstore
    image: micheal65536/vienna:objectstore-latest
    hostname: objectstore
    networks:
      - genoa_internal
    volumes:
      - genoa-objectstore_data:/data
    restart: unless-stopped

  apiserver:
    container_name: ProjectGenoaAPIServer
    env_file:
      - .env
    image: micheal65536/vienna:apiserver-latest
    command: -eventbus eventbus -objectstore objectstore
    hostname: apiserver
    networks:
      - genoa_internal
      - genoa_external
    ports:
      - ${API_PORT}:8080
    volumes:
      - genoa-static_data:/static # Needs manual moving of files inside.
      - genoa-db_data:/data
    depends_on:
      - eventbus
      - objectstore
    restart: unless-stopped

  buildplate-launcher:
    container_name: ProjectGenoaBuildplateLauncher
    env_file:
      - .env
    image: micheal65536/vienna:buildplate-launcher-latest
    command: -eventbus eventbus -publicAddress ${ADDRESS}
    hostname: buildplate-launcher
    networks:
      - genoa_internal
      - genoa_external
    ports:
      - 19132-19141:19132-19141/udp
    depends_on:
      - eventbus
      - apiserver
    restart: unless-stopped

  tappablesgenerator:
    container_name: ProjectGenoaTappablesGenerator
    image: micheal65536/vienna:tappablesgenerator-latest
    command: -eventbus eventbus
    hostname: tappablesgenerator
    networks:
      - genoa_internal
      - genoa_external
    volumes:
      - genoa-static_data:/static # Needs manual moving of files inside.
    depends_on:
      - eventbus
    restart: unless-stopped

  cdn:
    container_name: ProjectGenoaCDN
    env_file:
      - .env
    image: micheal65536/vienna:utils-cdn-latest
    hostname: cdn
    networks:
      - genoa_external
    ports:
      - ${CDN_PORT}:8080
    volumes:
      - genoa-resourcepack_data:/data # Needs manual moving of files inside.
    restart: unless-stopped

  locator:
    container_name: ProjectGenoaLocator
    env_file:
      - .env
    image: micheal65536/vienna:utils-locator-latest
    command: -playfabTitleId 20CA2 -api http://${ADDRESS}:${API_PORT}/ -cdn http://${ADDRESS}:${CDN_PORT}/
    hostname: locator
    networks:
      - genoa_external
    ports:
      - ${LOCATOR_PORT}:8080
    restart: unless-stopped

  buildplate-importer:
    container_name: ProjectGenoaBuildplateImporter
    env_file:
      - .env
    image: micheal65536/vienna:utils-tools-buildplate-importer-latest
    command: -eventbus eventbus -objectstore objectstore -worldFile /world/world -playerId ${BUILDPLATE_IMPORTER_PLAYER_ID}
    hostname: buildplate-importer
    networks:
      - genoa_internal
    volumes:
      - genoa-db_data:/data
      - genoa-world_data:/world # Needs manual moving of files inside after start.

    depends_on:
      - objectstore
      - buildplate-launcher
    profiles:
      - buildplate-importer
    restart: no

networks:
  genoa_external:
    driver: bridge
    internal: false
  genoa_internal:
    driver: bridge
    internal: true
